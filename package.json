{
  "name": "@wave-av/moq-edge",
  "version": "0.1.0",
  "private": true,
  "description": "WAVE Media-over-QUIC edge relay — Cloudflare Worker + Durable Object implementation of IETF MoQ Transport (advertises draft-18, negotiates down to draft-07). Acts as a sub-second-latency CDN-on-CDN: customer encoders publish tracks via WebTransport, viewers subscribe globally with QUIC-native multiplexing.",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "dev": "wrangler dev",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run __tests__/",
    "typecheck": "tsc --noEmit",
    "tail": "wrangler tail moq-edge-production --format pretty"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "@wave-av/content-hash": "0.2.0",
    "@wave-av/spoke-chassis": "^0.12.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "@eslint/js": "^10.0.0",
    "eslint": "^9.39.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.7",
    "wrangler": "^4.0.0"
  }
}
